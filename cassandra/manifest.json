{
  "version": "1.0.0",
  "selectors": ["cassandra"],
  "deploy_parallel_count": 1,
  "update_parallel_count": 1,
  "certs": {
    "internode": {
      "pkcs8": true,
      "one": false,
      "subject": {
        "common_name": "cassandra"
      }
    }
  },
  "resources": {
    "memory": { "min": "1024 mb", "max": "4096 mb" },
    "ports": {
      "cassandra_cql_port": {},
      "cassandra_jmx_port": {},
      "cassandra_metrics_port": {},
      "cassandra_storage_port": {},
      "cassandra_ssl_storage_port": {}
    }
  },
  "commands": {
    "command_ensure_secrets": {
      "executed_on": ["post_build"]
    },
    "command_wait_up": {
      "executed_on": ["after_allocation_started"]
    },
    "command_y_init_admin": {
      "executed_on": ["after_allocation_started"]
    },
    "command_cluster_status": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    },
    "command_update_admin_password": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    }
  },
  "health_check": {
    "checks": [
      { "type": "tcp", "port": "cassandra_cql_port" },
      { "type": "http", "port": "cassandra_metrics_port", "path": "/metrics", "expect_status": 200 }
    ],
    "timeout_seconds": 10,
    "wait": { "attempts": 60, "interval_seconds": 5 }
  }
}
