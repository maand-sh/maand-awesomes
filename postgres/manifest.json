{
  "version": "2.5.9",
  "deploy_parallel_count": 1,
  "update_parallel_count": 1,
  "certs": {
    "server": {
      "pkcs8": false,
      "one": false,
      "subject": {
        "common_name": "postgres"
      }
    },
    "zookeeper_client": {
      "pkcs8": true,
      "one": true,
      "subject": {
        "common_name": "postgres-zookeeper-client"
      }
    }
  },
  "resources": {
    "memory": { "min": "4 gb", "max": "64 gb" },
    "cpu": { "min": "2400 mhz", "max": "24000 mhz" },
    "ports": {
      "postgres_port_pg": {},
      "postgres_port_patroni": {},
      "postgres_port_postgres_exporter": {}
    }
  },
  "health_check": {
    "checks": [
      {
        "type": "tcp",
        "port": "postgres_port_pg"
      }
    ],
    "timeout_seconds": 10,
    "wait": { "attempts": 36, "interval_seconds": 5 }
  },
  "commands": {
    "command_ensure_secrets": {
      "executed_on": ["post_build"]
    },
    "command_plan_order": {
      "executed_on": ["pre_deploy"]
    },
    "command_service": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    },
    "command_cluster_status": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    },
    "command_wait_zookeeper": {
      "executed_on": ["pre_deploy"],
      "demands": {
        "job": "zookeeper",
        "command": "command_service",
        "config": {}
      }
    }
  }
}
