{
  "version": "1.0.0",
  "selectors": ["prometheus"],
  "resources": {
    "ports": {
      "prometheus_port_http": 9090
    }
  },
  "health_check": {
    "checks": [
      { "type": "http", "port": "prometheus_port_http", "path": "/metrics", "expect_status": 200 }
    ],
    "timeout_seconds": 5,
    "wait": { "attempts": 60, "interval_seconds": 2 }
  }
}
