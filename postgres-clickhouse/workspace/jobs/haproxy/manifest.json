{
  "version": "1.2.2",
  "selectors": ["haproxy"],
  "resources": {
    "ports": {
      "haproxy_port_postgres": 6432,
      "haproxy_port_clickhouse_native_write": 9006,
      "haproxy_port_clickhouse_native_read": 9007,
      "haproxy_port_metrics": 8404
    }
  },
  "health_check": {
    "checks": [
      { "type": "tcp", "port": "haproxy_port_postgres" },
      { "type": "tcp", "port": "haproxy_port_clickhouse_native_write" },
      { "type": "tcp", "port": "haproxy_port_clickhouse_native_read" },
      {
        "type": "http",
        "port": "haproxy_port_metrics",
        "path": "/metrics",
        "expect_status": 200
      }
    ],
    "timeout_seconds": 5,
    "wait": { "attempts": 30, "interval_seconds": 2 }
  },
  "commands": {
    "command_service": {
      "executed_on": ["cli"],
      "demands": {
        "job": "postgres",
        "command": "command_service",
        "config": {
          "min_version": "2.3.0"
        }
      }
    },
    "command_wait_clickhouse": {
      "executed_on": ["pre_deploy"],
      "demands": {
        "job": "clickhouse",
        "command": "command_service",
        "config": {}
      }
    }
  }
}
