{
  "version": "1.0.0",
  "selectors": ["node_agent"],
  "update_parallel_count": 4,
  "resources": {
    "ports": {
      "node_agent_port_metrics": 9500,
      "node_agent_port_traces": 8080
    }
  },
  "health_check": {
    "checks": [
      { "type": "http", "port": "node_agent_port_metrics", "path": "/metrics", "expect_status": 200 }
    ],
    "timeout_seconds": 5,
    "wait": { "attempts": 60, "interval_seconds": 2 }
  }
}
