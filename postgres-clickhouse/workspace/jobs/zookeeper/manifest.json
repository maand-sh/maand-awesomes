{
  "version": "1.0.3",
  "selectors": ["zookeeper"],
  "update_parallel_count": 1,
  "resources": {
    "ports": {
      "zookeeper_port_client": 2181,
      "zookeeper_port_follower": 2888,
      "zookeeper_port_election": 3888,
      "zookeeper_port_metrics": 7000
    }
  },
  "health_check": {
    "checks": [
      { "type": "tcp", "port": "zookeeper_port_client" },
      { "type": "http", "port": "zookeeper_port_metrics", "path": "/metrics", "expect_status": 200 }
    ],
    "timeout_seconds": 5,
    "wait": { "attempts": 60, "interval_seconds": 2 }
  },
  "commands": {
    "command_service": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    }
  }
}
