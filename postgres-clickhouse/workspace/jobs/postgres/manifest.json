{
  "version": "2.3.5",
  "selectors": ["postgres"],
  "update_parallel_count": 1,
  "certs": {
    "server": {
      "pkcs8": false,
      "one": false,
      "subject": {
        "common_name": "postgres"
      }
    }
  },
  "resources": {
    "ports": {
      "postgres_port_pg": 5432,
      "postgres_port_patroni": 8008,
      "postgres_port_postgres_exporter": 9187
    }
  },
  "health_check": {
    "checks": [
      {
        "type": "http",
        "port": "postgres_port_patroni",
        "path": "/liveness",
        "expect_status": 200
      }
    ],
    "timeout_seconds": 10,
    "wait": { "attempts": 36, "interval_seconds": 5 }
  },
  "commands": {
    "command_service": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    },
    "command_wait_zookeeper": {
      "executed_on": ["pre_deploy"],
      "demands": {
        "job": "zookeeper",
        "command": "command_service",
        "config": {}
      }
    }
  }
}
