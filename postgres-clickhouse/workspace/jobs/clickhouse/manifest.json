{
  "version": "1.0.1",
  "selectors": ["clickhouse"],
  "resources": {
    "ports": {
      "clickhouse_port_http": 8123,
      "clickhouse_port_native": 9000,
      "clickhouse_port_interserver_tls": 9010,
      "clickhouse_port_native_tls": 9440,
      "clickhouse_port_metrics": 9363
    }
  },
  "health_check": {
    "checks": [
      { "type": "http", "port": "clickhouse_port_http", "path": "/ping", "expect_status": 200 },
      { "type": "tcp", "port": "clickhouse_port_native" },
      { "type": "tcp", "port": "clickhouse_port_interserver_tls" },
      { "type": "tcp", "port": "clickhouse_port_native_tls" },
      { "type": "http", "port": "clickhouse_port_metrics", "path": "/metrics", "expect_status": 200 }
    ],
    "timeout_seconds": 10,
    "wait": { "attempts": 30, "interval_seconds": 1 }
  },
  "certs": {
    "server": {
      "pkcs8": false,
      "one": false,
      "subject": {
        "common_name": "clickhouse"
      }
    }
  },
  "commands": {
    "command_service": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    }
  }
}
