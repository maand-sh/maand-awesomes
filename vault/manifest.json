{
  "version": "2.3.1",
  "selectors": ["vault"],
  "deploy_parallel_count": 1,
  "update_parallel_count": 1,
  "resources": {
    "memory": { "min": "256 mb", "max": "2048 mb" },
    "cpu": { "min": "1200 mhz", "max": "9600 mhz" },
    "ports": {
      "vault_port_api": {},
      "vault_port_cluster": {}
    }
  },
  "health_check": {
    "checks": [
      { "type": "tcp", "port": "vault_port_api" }
    ],
    "timeout_seconds": 10,
    "wait": { "attempts": 60, "interval_seconds": 5 }
  },
  "certs": {
    "server": {
      "pkcs8": false,
      "one": false,
      "subject": {
        "common_name": "vault"
      }
    }
  },
  "commands": {
    "command_plan_order": {
      "executed_on": ["pre_deploy"]
    },
    "command_node_up": {
      "executed_on": ["after_allocation_started"]
    },
    "command_unseal": {
      "executed_on": ["cli"]
    },
    "command_cluster_status": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    }
  }
}
