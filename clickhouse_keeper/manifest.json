{
  "version": "1.0.6",
  "selectors": ["clickhouse_keeper"],
  "resources": {
    "memory": { "min": "256 mb", "max": "2048 mb" },
    "cpu": { "min": "1200 mhz", "max": "9600 mhz" },
    "ports": {
      "clickhouse_keeper_port_client_tls": {},
      "clickhouse_keeper_port_raft": {},
      "clickhouse_keeper_port_metrics": {}
    }
  },
  "health_check": {
    "checks": [
      { "type": "http", "port": "clickhouse_keeper_port_metrics", "path": "/metrics", "expect_status": 200 }
    ],
    "timeout_seconds": 10,
    "wait": { "attempts": 30, "interval_seconds": 1 }
  },
  "certs": {
    "server": {
      "pkcs8": false,
      "one": false,
      "subject": {
        "common_name": "clickhouse-keeper"
      }
    }
  },
  "commands": {
    "command_service": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    }
  }
}
