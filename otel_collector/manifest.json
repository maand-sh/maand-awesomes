{
  "version": "1.1.2",
  "selectors": ["otel_collector"],
  "resources": {
    "memory": { "min": "256 mb", "max": "1024 mb" },
    "cpu": { "min": "600 mhz", "max": "4800 mhz" },
    "ports": {
      "otel_collector_port_grpc": {},
      "otel_collector_port_http": {},
      "otel_collector_port_metrics": {},
      "otel_collector_port_health": {}
    }
  },
  "health_check": {
    "checks": [
      { "type": "http", "port": "otel_collector_port_health", "path": "/", "expect_status": 200 }
    ],
    "timeout_seconds": 5,
    "wait": { "attempts": 60, "interval_seconds": 2 }
  },
  "commands": {
    "command_wait_clickhouse": {
      "executed_on": ["pre_deploy"]
    },
    "command_service": {
      "executed_on": ["cli"],
      "demands": {
        "job": "",
        "command": "",
        "config": {}
      }
    }
  }
}
